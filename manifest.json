{
  "manifest_version": 3,
  "name": "IG Video Controls",
  "version": "1.1.0",
  "description": "Full video controls for Instagram: seekable progress bar, volume slider, fullscreen, and mute shortcut (M key)",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["*://www.instagram.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
